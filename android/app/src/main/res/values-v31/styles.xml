<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash: white screen without launcher icon. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/transparent_splash_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/white</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
</resources>
